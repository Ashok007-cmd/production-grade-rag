# =============================================================================
# RAG Pipeline Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys.

# LLM Provider: "openai" or "anthropic"
RAG_LLM_PROVIDER=openai

# OpenAI (default backend)
OPENAI_API_KEY=sk-your-openai-api-key
RAG_LLM_MODEL=gpt-4o-mini

# Anthropic (alternative backend, set RAG_LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# RAG_LLM_MODEL=claude-haiku-4-5-20251001

# Paths
RAG_DATA_DIR=data
RAG_CHROMA_PATH=data/chroma_db

# Chunking
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=150

# Retrieval
RAG_TOP_K_RETRIEVAL=20
RAG_TOP_K_RERANK=5
RAG_TOP_K_FINAL=5

# Hybrid Search (Phase 2)
RAG_HYBRID_ALPHA=0.6

# Re-ranker (Phase 2)
RAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Evaluation (Phase 3)
RAG_FAITHFULNESS_THRESHOLD=0.7

# Logging
RAG_LOG_LEVEL=INFO

# API Security
# Comma-separated list of allowed CORS origins, or * to allow all (development default).
# Example for production: RAG_CORS_ORIGINS=https://myapp.example.com,https://admin.example.com
RAG_CORS_ORIGINS=*

# Optional API key — set to require "Authorization: Bearer <key>" on all requests.
# Leave unset (or empty) to disable auth for local development.
# RAG_API_KEY=your-secret-api-key

# =============================================================================
# Monitoring (Phase 3) — all optional, gracefully degraded when unset
# =============================================================================
# MONITOR_ENABLED=true
# MONITOR_LANGFUSE_SECRET_KEY=sk-lf-...
# MONITOR_LANGFUSE_PUBLIC_KEY=pk-lf-...
# MONITOR_LANGFUSE_HOST=https://cloud.langfuse.com
# MONITOR_OTEL_SERVICE_NAME=rag-pipeline
# MONITOR_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# MONITOR_CIRCUIT_BREAKER_THRESHOLD=3
# MONITOR_CIRCUIT_BREAKER_COOLDOWN_SECONDS=30.0
